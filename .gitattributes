# Normalize all text to LF in the repository and on checkout.
# This repo is born with LF enforced so config files (JSON/YAML) never
# inherit a CRLF phantom that breaks drift checks or diffs on Windows.
* text=auto eol=lf

# Explicit text types (belt and suspenders).
*.json   text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.js     text eol=lf
*.cjs    text eol=lf
*.mjs    text eol=lf
*.html   text eol=lf
*.css    text eol=lf
*.txt    text eol=lf
*.cursorrules text eol=lf
.gitignore    text eol=lf
.gitattributes text eol=lf
LICENSE  text eol=lf

# Binary assets - never normalize, never diff.
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.woff2  binary
*.mp4    binary
*.mkv    binary
*.mov    binary
*.webm   binary
